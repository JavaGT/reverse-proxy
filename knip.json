{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["pino-pretty"],
  "workspaces": {
    ".": {
      "entry": [
        "src/infrastructure/http/ui/mgmt-app.mjs",
        "src/management/bootstrapFromPersistence.mjs",
        "tests/**/*.mjs"
      ],
      "project": ["src/**/*.mjs", "tests/**/*.mjs"],
      "ignoreUnresolved": ["/isValidApexFqdn.mjs"]
    },
    "packages/reverse-proxy-client": {
      "entry": "tests/*.mjs",
      "project": ["src/**/*.mjs", "bin/**/*.mjs", "tests/**/*.mjs"]
    }
  }
}
