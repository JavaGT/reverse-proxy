# --- Bootstrap (not stored in SQLite) ---
# Path to the SQLite file used for routes, meta (domains, DDNS, server settings), etc.
SQLITE_DB_PATH=./reverse-proxy.db

# TLS certificate directory (required for the data plane to start; can also be set in Settings → saved to SQLite).
TLS_CERT_DIR=/path/to/letsencrypt/your-domain.com

# Optional: Node environment (development vs production tooling).
# NODE_ENV=production

# --- Everything below can live in SQLite instead ---
# Use the management UI Settings page (/settings.html) or PUT /api/v1/settings.
# Values in meta.server_settings override these on startup and after save.

# Comma-separated apex domains until you save apexes via PUT /api/v1/domains (SQLite).
# ROOT_DOMAINS=your-domain.com,another-domain.org

# MANAGEMENT_SUBDOMAIN=reverse-proxy
# MANAGEMENT_INTERFACE_PORT=24789
# MANAGEMENT_BASE_DOMAIN=your-domain.com
# HEALTH_CHECK_INTERVAL_MS=30000
# PUBLIC_URL_HTTPS_PREFIX=https
# PUBLIC_URL_HTTP_PREFIX=http
# LOG_REQUESTS=false

# MANAGEMENT_TRUST_PROXY=1
# MANAGEMENT_RATE_LIMIT_MAX=300
# MANAGEMENT_RATE_LIMIT_WINDOW_MS=60000
# MANAGEMENT_DEBUG_LOCAL_OPERATOR=0
# MANAGEMENT_LOCAL_OPERATOR_IPS=
# MANAGEMENT_AUTO_PUBLIC_EGRESS_IP=0

# MANAGEMENT_REGISTRATION_SECRET=
# MANAGEMENT_SESSION_SECRET=
# MANAGEMENT_AUTH_RP_ID=your-domain.com
# MANAGEMENT_AUTH_ORIGIN=https://your-domain.com
# MANAGEMENT_AUTH_COOKIE_SECURE=1
# MANAGEMENT_AUTH_DATA_DIR=

# DNS_LOOKUP_TIMEOUT_MS=5000
# DNS_CONSOLE_DEFAULT_PROVIDER=porkbun
# IP_LOOKUP_TIMEOUT_MS=8000
# PUBLIC_INGRESS_PROBE_HTTPS_PORT=443
# PUBLIC_INGRESS_PROBE_TIMEOUT_MS=5000
