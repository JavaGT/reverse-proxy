TLS_CERT_DIR=/path/to/letsencrypt/your-domain.com

# Comma-separated apex domains this proxy serves (first is primary default for reserve/release).
ROOT_DOMAINS=your-domain.com,another-domain.org
# Legacy single-domain alias (used if ROOT_DOMAINS unset)
# ROOT_DOMAIN=your-domain.com

SQLITE_DB_PATH=./reverse-proxy.db
# One-time migration: import routes from legacy JSON if the DB is new
ROUTE_CACHE_FILE=./route-cache.json

MANAGEMENT_SUBDOMAIN=reverse-proxy
# Localhost port for management UI/API (127.0.0.1)
MANAGEMENT_INTERFACE_PORT=24789
# Which apex the management UI/API is registered under (default: first ROOT_DOMAIN)
# MANAGEMENT_BASE_DOMAIN=your-domain.com
# Optional: bearer token for mutating management API calls (same value as Authorization header)
# MANAGEMENT_SECRET=
# Management API rate limit (global): max requests per window
# MANAGEMENT_RATE_LIMIT_MAX=300
# MANAGEMENT_RATE_LIMIT_WINDOW_MS=60000
LOG_REQUESTS=false
HEALTH_CHECK_INTERVAL_MS=30000
# DNS lookups for GET /api/v1/network (A/AAAA per apex + wildcard probe only)
# DNS_LOOKUP_TIMEOUT_MS=5000
# HTTPS self-probe from this server to its own public IP (port forward / hairpin hint; default 443)
# PUBLIC_INGRESS_PROBE_HTTPS_PORT=443
# PUBLIC_INGRESS_PROBE_TIMEOUT_MS=5000

PUBLIC_URL_HTTPS_PREFIX=https
PUBLIC_URL_HTTP_PREFIX=http

# Optional: default DNS management links for configured apexes (UI/API). Same as sqlite dnsConsole.defaultProvider.
# DNS_CONSOLE_DEFAULT_PROVIDER=porkbun

